name: PR Branch Check

on:
  pull_request:
    branches:
      - main

jobs:
  check-branch:
    runs-on: ubuntu-latest
    steps:
      - name: Verify source branch is develop
        run: |
          if [ "${{ github.head_ref }}" != "develop" ]; then
            echo "❌ Pull requests to main must come from the 'develop' branch."
            echo "   This PR comes from '${{ github.head_ref }}'."
            exit 1
          fi
          echo "✅ Source branch is 'develop'. All good!"
